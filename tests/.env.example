# Serial ports per sketch.yaml profile.
# Profile names are uppercased by pytest-embedded
# (e.g. profile `esp32` -> TEST_SERIAL_PORT_ESP32).
# The default `host` profile uses a socket and does not need a serial port.
TEST_SERIAL_PORT_ESP32=/dev/ttyACM0

# Optional: generate an HTML report
#PYTEST_ADDOPTS="--html=report.html --self-contained-html"
